rules_version = '2';

// RoadMate AU security rules.
// Identity may be anonymous Firebase Auth or optional social sign-in.
// Posture: signed-in users may read sites/reports; cast status votes (validated
// so a vote bumps exactly one counter by 1); post activity reports; save sites
// under their own uid; and submit NEW sites as *pending* (approved == false).
// Official seeded sites (approved == true) and moderation actions are
// admin-managed.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isInitialAdminEmail() {
      return signedIn()
        && request.auth.token.email in [
          'r3procamel@gmail.com',
          'hello@adrian2045.com',
          'adrian@darumatic.com'
        ];
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/userRoles/$(request.auth.uid))
        && get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'admin';
    }

    match /sites/{siteId} {
      allow read: if true;

      // Community-submitted sites are created as pending (approved == false);
      // they only become visible after a moderator approves them.
      allow create: if signedIn() && isValidNewSite();

      // Two permitted update shapes:
      //  - a validated status vote (one counter +1, valid status), or
      //  - a bare lastReportAt touch (accompanies an activity report).
      allow update: if isAdmin()
        || (signedIn() && (isValidVote() || isReportTouch()));

      allow delete: if false;

      match /reports/{reportId} {
        allow read: if true;
        allow create: if signedIn() && isValidReport(siteId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // Authorises the admin moderation feed's collectionGroup('reports') query.
    // Rules v2 does not apply the nested /sites/{id}/reports rule to collection
    // group queries — those need a recursive-wildcard match. Per-doc reads stay
    // governed by the nested rule above (public); this only gates the group scan.
    match /{path=**}/reports/{reportId} {
      allow read: if isAdmin();
    }

    match /userRoles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && isInitialAdminEmail()
        && request.resource.data.keys().hasOnly([
          'role', 'email', 'bootstrappedAt'
        ])
        && request.resource.data.role == 'admin'
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.bootstrappedAt == request.time;
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'email', 'displayName', 'photoUrl', 'isAnonymous', 'lastSeenAt'
        ]);
      allow delete: if false;

      // A user's favourite sites live under their own uid and are private to them.
      match /favourites/{siteId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }
    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Exactly one of the three status counters increases by 1; none decrease;
    // currentStatus is a valid value; no other fields change.
    function isValidVote() {
      let a = resource.data;
      let b = request.resource.data;
      return affectedKeys().hasOnly(
               ['openVotes', 'blitzVotes', 'closedVotes',
                'currentStatus', 'lastReportAt'])
        && b.currentStatus in ['open', 'blitz', 'closed']
        && b.openVotes >= a.openVotes
        && b.blitzVotes >= a.blitzVotes
        && b.closedVotes >= a.closedVotes
        && (b.openVotes + b.blitzVotes + b.closedVotes)
             == (a.openVotes + a.blitzVotes + a.closedVotes) + 1;
    }

    function isReportTouch() {
      return affectedKeys().hasOnly(['lastReportAt']);
    }

    function isValidReport(siteId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'siteId', 'status', 'activityType', 'activityNote', 'reporterName',
          'uid', 'createdAt'
        ])
        && d.uid == request.auth.uid
        && d.siteId == siteId
        && d.createdAt == request.time
        && (isValidStatusReport(d) || isValidActivityReport(d));
    }

    function isValidStatusReport(d) {
      return d.keys().hasOnly(['siteId', 'status', 'uid', 'createdAt'])
        && d.status is string
        && d.status in ['open', 'blitz', 'closed'];
    }

    function isValidActivityReport(d) {
      return d.keys().hasOnly([
          'siteId', 'activityType', 'activityNote', 'reporterName',
          'uid', 'createdAt'
        ])
        && d.activityType is string
        && d.activityType in [
          'longQueue', 'delays', 'policePresent', 'defectChecks',
          'noActivity', 'other'
        ]
        && (!('activityNote' in d.keys())
          || (d.activityNote is string && d.activityNote.size() <= 500))
        && (!('reporterName' in d.keys())
          || (d.reporterName is string
            && d.reporterName.size() > 0
            && d.reporterName.size() <= 80));
    }

    function isValidNewSite() {
      let d = request.resource.data;
      return d.approved == false
        && d.createdBy == request.auth.uid
        && d.name is string && d.name.size() > 0
        && d.state is string
        && d.type is string
        && d.address is string;
    }
  }
}
